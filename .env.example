APP_NAME="Membra SMS Bitcoin Relay"
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://membra:membra@localhost:5432/membra_sms
API_SECRET=change-me
PUBLIC_BASE_URL=http://localhost:8000

# SMS provider placeholders
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional balance provider
BITCOIN_BALANCE_PROVIDER=mock
MEMPOOL_SPACE_BASE_URL=https://mempool.space/api

# Security limits
MAX_SMS_SEND_SATS=100000
MAX_SMS_APPROVE_SATS=100000
REQUIRE_SECURE_LINK_FOR_ALL_PAYMENTS=true
